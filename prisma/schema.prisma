generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  PEMERINTAH
  UMKM
}

enum PlaceCategory {
  WISATA
  HOTEL
  RESTO
}

enum PlaceStatus {
  BEROPERASI
  TUTUP
}

enum OwnershipType {
  PUBLIK
  PRIVAT
  TIDAK_DIKETAHUI
}

enum IssueCategory {
  PARKIR
  TOILET
  AKSES
  KEBERSIHAN
  HARGA
  PELAYANAN
  LAINNYA
}

enum BpodtVerification {
  BELUM_DICEK
  SINKRON
  TIDAK_SINKRON
}

enum ReportStatus {
  BARU
  DITINJAU
  DIPROSES
  SELESAI
  DITOLAK
}

enum SourceChannel {
  WEB
  SEED_DATASET
}

model User {
  id             String     @id @default(uuid())
  name           String
  email          String     @unique
  passwordHash   String
  role           Role       @default(UMKM)
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  createdById    String?
  createdBy      User?      @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers   User[]     @relation("UserCreatedBy")

  managedPlaces  Place[]    @relation("PlaceOwner")
  reportsFiled   Report[]   @relation("ReportFiledBy")
  reportsHandled Report[]   @relation("ReportHandledBy")
  budgetApprovals BudgetProposal[] @relation("BudgetApprovedBy")
  auditLogs      AuditLog[]

  @@map("users")
}

model Place {
  id                     String         @id @default(uuid())
  placeCode              String         @unique // e.g. WIS-001, HTL-014, RES-089 (from cleaned dataset)
  name                   String
  category               PlaceCategory
  subtype                String?
  starRating             Int?           // hotel only
  priceMin               Float?
  priceMax               Float?
  priceRaw               String?
  latitude               Float?
  longitude              Float?
  address                String?
  operationalHour        String?
  rating                 Float?
  status                 PlaceStatus    @default(BEROPERASI)
  facilitiesOrActivities String?
  description            String?
  ownershipType          OwnershipType  @default(TIDAK_DIKETAHUI)
  ownerName              String?
  bpodtVerified          BpodtVerification @default(BELUM_DICEK)
  bpodtNote              String?
  bpodtAuditDetail       Json?

  ownerId                String?
  owner                  User?          @relation("PlaceOwner", fields: [ownerId], references: [id])

  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  reviews                Review[]
  reports                Report[]
  issueSummaries         PlaceIssueSummary[]
  budgetProposal         BudgetProposal?
  roadAccessRoute        RoadAccessRoute?

  @@index([category])
  @@index([ownershipType])
  @@map("places")
}

model Review {
  id               String    @id @default(uuid())
  placeId          String?
  place            Place?    @relation(fields: [placeId], references: [id])
  placeNameRaw     String    // original name as scraped, kept even if unmatched to a Place
  reviewerName     String?
  reviewerRating   Float?
  reviewText       String?
  publishedAtRaw   String?
  scrapedAtDate    DateTime?
  reviewerType     String?
  createdAt        DateTime  @default(now())

  issueTags        ReviewIssueTag[]

  @@index([placeId])
  @@map("reviews")
}

model ReviewIssueTag {
  id         String        @id @default(uuid())
  reviewId   String
  review     Review        @relation(fields: [reviewId], references: [id])
  category   IssueCategory
  isNegative Boolean       @default(true)
  confidence Float?
  createdAt  DateTime      @default(now())

  @@unique([reviewId, category])
  @@index([category])
  @@map("review_issue_tags")
}

// Aggregated, precomputed gap-score per place per category so the map/dashboard
// doesn't have to re-scan raw reviews on every request.
model PlaceIssueSummary {
  id             String        @id @default(uuid())
  placeId        String
  place          Place         @relation(fields: [placeId], references: [id])
  category       IssueCategory
  negativeCount  Int           @default(0)
  totalMentions  Int           @default(0)
  gapScore       Float         @default(0) // negativeCount / totalMentions
  lastComputedAt DateTime      @default(now())

  @@unique([placeId, category])
  @@map("place_issue_summaries")
}

enum FundingSource {
  APBD
  KEMENPAREKRAF
}

enum BudgetProposalStatus {
  MENUNGGU
  DISETUJUI
  DICAIRKAN
  DITOLAK
}

model BudgetProposal {
  id                String               @id @default(uuid())
  placeId           String
  place             Place                @relation(fields: [placeId], references: [id])
  worstCategory     IssueCategory
  worstGapScore     Float
  urgencyScore      Float
  affectedUmkmCount Int                  @default(0)
  status            BudgetProposalStatus @default(MENUNGGU)
  approvedAmount    Float?
  fundingSource     FundingSource?
  approvedById      String?
  approvedBy        User?                @relation("BudgetApprovedBy", fields: [approvedById], references: [id])
  notes             String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@unique([placeId])
  @@index([status])
  @@index([urgencyScore])
  @@map("budget_proposals")
}

enum RouteType {
  DARAT
  FERRY
}

model TransportRoute {
  id               String     @id @default(uuid())
  transportName    String
  vehicleType      String?
  routeType        RouteType
  routeCities      String[]
  routeDescription String
  priceMin         Float?
  priceMax         Float?
  priceRaw         String?
  operationalHour  String?
  description      String?
  createdAt        DateTime   @default(now())

  @@index([routeType])
  @@map("transport_routes")
}

enum ArticleCategory {
  ARTIKEL
  INFO_UMUM
}

model KnowledgeArticle {
  id         String           @id @default(uuid())
  category   ArticleCategory
  title      String
  kabupaten  String?
  content    String
  sourceUrl  String?
  createdAt  DateTime         @default(now())

  @@index([category])
  @@map("knowledge_articles")
}

model RoadAccessRoute {
  id             String   @id @default(uuid())
  placeId        String   @unique
  place          Place    @relation(fields: [placeId], references: [id])
  geometry       Json     // GeoJSON LineString coordinates from OSRM
  distanceKm     Float
  gapScore       Float?   // AKSES category gapScore, null if no AI data yet
  negativeCount  Int      @default(0)
  totalMentions  Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("road_access_routes")
}

model Report {
  id             String       @id @default(uuid())
  placeId        String
  place          Place        @relation(fields: [placeId], references: [id])
  category       IssueCategory
  title          String
  description    String
  status         ReportStatus @default(BARU)
  sourceChannel  SourceChannel @default(WEB)

  filedById      String
  filedBy        User         @relation("ReportFiledBy", fields: [filedById], references: [id])

  handledById    String?
  handledBy      User?        @relation("ReportHandledBy", fields: [handledById], references: [id])
  responseNote   String?
  respondedAt    DateTime?

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([placeId])
  @@index([status])
  @@index([filedById])
  @@map("reports")
}

model AuditLog {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  action        String
  entityType    String
  entityId      String?
  detail        Json?
  sourceChannel SourceChannel @default(WEB)
  createdAt     DateTime      @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
